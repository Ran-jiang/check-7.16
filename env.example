# CCitecheck 配置示例 — 复制为 .env 并填入实际值

# ============ v0.2 LLM 抽取 ============
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60

# ============ v0.3 法条检索层 ============

# 第二层 gov_search：腾讯云联网搜索（site=gov.cn 限定）
# 开通产品后在 https://console.cloud.tencent.com/cam/capi 获取
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
# 以下默认值一般无需修改（以联网搜索 API 文档为准）
# WSA_HOST=wsa.tencentcloudapi.com
# WSA_ACTION=SearchPro
# WSA_VERSION=2025-05-08

# 第三层 pkulaw：北大法宝 MCP（精准查找法条网关）
# headers 为 JSON 字符串，鉴权头从你的 MCP 客户端配置（~/.claude.json）里复制
PKULAW_MCP_URL=https://apim-gateway.pkulaw.com/mcp-fatiao
PKULAW_MCP_HEADERS={"Authorization": "Bearer xxxx"}
