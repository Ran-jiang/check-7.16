    {
      "claim_id": "cl_00006",
      "claim_type": "case_holding_paraphrase",
      "text": "在（2018）最高法民申3583号案件中，最高人民法院也明确该裁判要旨，以“该条规定没有禁止商业银行在进行经营业务的同时进行其他民事行为”认定该案中行长代表农商行晋都路支行进行的民事行为未超越其职权。",
      "anchor_ids": [
        "line00047"
      ],
      "block_ids": [
        "b_00033"
      ],
      "verification_route": "case_database_fulltext",
