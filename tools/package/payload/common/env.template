# CCiteheck 环境变量 — 由发布流程注入密钥后随安装包分发。
# 若你看到的是 .env.template 且密钥为空，说明这是无密钥构建产物，
# 需运行 tools/release/inject_env.sh 注入，或手工复制为 .env 并填入密钥。

# 千问引用忠实度核查（必填）
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
QWEN_MAX_MODEL=qwen3.7-max
# 两个千问模型可用各自独立的 key；留空则回退用上面的 DASHSCOPE_API_KEY
QWEN_PLUS_API_KEY=
QWEN_MAX_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_SEMANTIC_WORKERS=8
QWEN_TIMEOUT_SECONDS=60
QWEN_RETRY_BUDGET_SECONDS=90
QWEN_RETRY_MAX_ATTEMPTS=4
QWEN_SALVAGE_MAX=8

# 北大法宝法规/法条/案例 MCP（可选，未配置时相关核查标记为未配置）
PKULAW_ACCESS_TOKEN=
PKULAW_MCP_GATEWAY=https://apim-gateway.pkulaw.com
PKULAW_LOOKUP_WORKERS=8

# 本机安装包默认关闭完整调试现场（避免敏感原文落盘）
CCITECHECK_DEBUG_CAPTURE=0

# EUR-Lex 欧盟法规（安装包内置本地服务，端点固定，勿改）
EURLEX_MCP_GATEWAY=http://127.0.0.1:3010/mcp
EURLEX_SEARCH_TOOL=search

# DeepSeek 官方 API（前端可选模型之一；platform.deepseek.com）
# 官方独立密钥，勿复用千问的 DASHSCOPE_API_KEY；密钥在打包/安装时注入
# 可选调用名：deepseek-v4-pro（强）/ deepseek-v4-flash（快）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认使用哪个模型（qwen3.7-plus / qwen3.7-max / deepseek）
LLM_DEFAULT_MODEL=qwen3.7-plus
