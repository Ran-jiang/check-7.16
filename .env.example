# CCiteheck 环境变量（唯一配置文件）— 复制为 .env 并填入实际值。
# 默认流程开启语义核查，因此 DASHSCOPE_API_KEY 默认必填。
# 仅运行 CLI 的 --no-semantic-check 时可以不配置该项。

# 千问引用忠实度核查（不评价法律论证是否成立）。
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 语义核查传输层阀门；默认值兼顾正常路径吞吐与失败路径时限。
QWEN_SEMANTIC_WORKERS=4
QWEN_TIMEOUT_SECONDS=60
QWEN_RETRY_BUDGET_SECONDS=90
QWEN_RETRY_MAX_ATTEMPTS=4
QWEN_SALVAGE_MAX=8

# 北大法宝法规/法条/案例多路 MCP。需在法宝控制台订阅对应服务。
PKULAW_ACCESS_TOKEN=
PKULAW_MCP_GATEWAY=https://apim-gateway.pkulaw.com
# 北大法宝批量查询并发数（纯网络 IO，默认 8）。
PKULAW_LOOKUP_WORKERS=8
# 本机测试时完整保存 DOCX、解析结果、核查响应和 Word 操作事件；设为 0 可关闭。
CCITECHECK_DEBUG_CAPTURE=1

# 可选：EUR-Lex 欧盟法规 MCP 网关（配置后欧盟法规走 EUR-Lex 存在性核验）
# EURLEX_MCP_GATEWAY=https://your-eurlex-mcp-endpoint
# EURLEX_ACCESS_TOKEN=
# EURLEX_SEARCH_TOOL=search
